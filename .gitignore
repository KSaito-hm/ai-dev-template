# .gitignore
# 言語・環境に合わせて適宜追加・削除してください

# ===========================
# OS
# ===========================
.DS_Store
Thumbs.db
Desktop.ini

# ===========================
# エディタ・IDE
# ===========================
.vscode/
.idea/
*.swp
*.swo

# ===========================
# Python
# ===========================
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ===========================
# Node.js / JavaScript
# ===========================
node_modules/
npm-debug.log*
yarn-error.log*
.npm/
dist/
.next/
.nuxt/

# ===========================
# 環境変数・シークレット
# ===========================
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# ===========================
# ログ・一時ファイル
# ===========================
*.log
tmp/
temp/
.cache/

# ===========================
# テスト・カバレッジ
# ===========================
coverage/
.coverage
htmlcov/

# ===========================
# ビルド成果物
# ===========================
*.out
*.exe
*.dll
*.so

# ===========================
# プロジェクト固有
# ===========================
.claude/
setup_instructions.md
